---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Verge Kit</title>
  </head>
  <body class="bg-neutral-300">
    <div class="p-16">
      <img class="block mb-8 w-48" src="/vk-crane-a.svg" />
      <div class="text-2xl text-neutral-800 leading-9 max-w-2xl">
        <p class="mb-6">
          <!-- <a
            href="https://github.com/jyoungblood/vergekit"
            target="_blank"
            class="underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            >Verge Kit</a
          > -->
          <span class="font-bold text-4xl pr-1">Verge Kit</span> is a solid foundation for building web applications with
          <a
            href="https://astro.build"
            target="_blank"
            class="tool-link underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            ><img
              src="/tool-logos/astro.svg"
              alt=""
              data-logo="astro"
              aria-hidden="true"
              class="tool-link-logo"
            /><span>Astro</span></a
          > and the <a
            href="https://workers.dev"
            target="_blank"
            class="tool-link underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            ><img
              src="/tool-logos/cloudflare-black.svg"
              alt=""
              aria-hidden="true"
              class="tool-link-logo"
              data-logo="cloudflare"
            /><span>Cloudflare Workers</span></a
          > ecosystem.
        </p>
        <p class="mb-6">
          Pre-wired with
          <a
            href="https://orm.drizzle.team"
            target="_blank"
            class="tool-link underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            ><img
              src="/tool-logos/drizzle.svg"
              alt=""
              aria-hidden="true"
              class="tool-link-logo"
            /><span>Drizzle</span></a
          >,
          <a
            href="https://www.better-auth.com"
            target="_blank"
            class="tool-link underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            ><img
              src="/tool-logos/better-auth.svg"
              alt=""
              aria-hidden="true"
              class="tool-link-logo"
            /><span>Better Auth</span></a
          >,
          <a
            href="https://tailwindcss.com"
            target="_blank"
            class="tool-link underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            ><img
              src="/tool-logos/tailwind-css.svg"
              alt=""
              aria-hidden="true"
              class="tool-link-logo"
            /><span>Tailwind</span></a
          >, and
          <a
            href="https://ui.bejamas.com"
            target="_blank"
            class="tool-link underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            ><img
              src="/tool-logos/bejamas-ui.svg"
              alt=""
              aria-hidden="true"
              class="tool-link-logo"
              data-logo="bejamas-ui"
            /><span>bejamas/ui</span></a
          >.
          <!-- Designed to deploy directly on Cloudflare using
          <a href="https://developers.cloudflare.com/d1/" target="_blank" class="underline underline-offset-4">D1</a>,
          <a href="https://developers.cloudflare.com/r2/" target="_blank" class="underline underline-offset-4">R2</a>,
          <a href="https://workers.dev" target="_blank" class="underline underline-offset-4">Workers</a>,
          <a href="https://developers.cloudflare.com/queues/" target="_blank" class="underline underline-offset-4">Queues</a>, and
          <a href="https://developers.cloudflare.com/kv/" target="_blank" class="underline underline-offset-4">KV</a>. -->
        </p>
        <p class="mb-6">
          We've also configured middleware, basic auth flows, route
          protection, user roles, and transactional email utilities.
        </p>
        <p class="mb-6">Start new apps with low effort and high confidence.</p>
      </div>

      <div class="landing-actions mt-10 flex flex-wrap items-center gap-4">
        <a href="/docs" class="btn">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-4 shrink-0 text-neutral-300"
            viewBox="0 0 448 512"
            aria-hidden="true"
            ><path
              fill="currentColor"
              d="M96 0C43 0 0 43 0 96v320c0 53 43 96 96 96h320c17.7 0 32-14.3 32-32s-14.3-32-32-32v-64c17.7 0 32-14.3 32-32V32c0-17.7-14.3-32-32-32zm0 384h256v64H96c-17.7 0-32-14.3-32-32s14.3-32 32-32m32-240c0-8.8 7.2-16 16-16h192c8.8 0 16 7.2 16 16s-7.2 16-16 16H144c-8.8 0-16-7.2-16-16m16 48h192c8.8 0 16 7.2 16 16s-7.2 16-16 16H144c-8.8 0-16-7.2-16-16s7.2-16 16-16"
            ></path></svg
          >
          Learn More
        </a>
        <a
          href="https://github.com/jyoungblood/vergekit"
          target="_blank"
          rel="noopener noreferrer"
          class="btn"
          data-variant="outline"
        >
          <svg
            class="size-4 shrink-0"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            ><path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path></svg
          >
          Source
        </a>
      </div>

      <!-- <a
        href="/docs"
        class="text-xs underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
        >Documentation</a
      > -->
    </div>
  </body>
</html>
