---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Verge Kit</title>
  </head>
  <body class="bg-neutral-300">
    <div class="p-16">
      <div class="text-2xl text-neutral-800 leading-9 max-w-2xl">
        <p class="mb-6">
          <a
            href="https://github.com/jyoungblood/vergekit"
            target="_blank"
            class="underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            >Verge Kit</a
          > is a solid foundation for building full-stack web applications<br /> with <a
            href="https://astro.build"
            target="_blank"
            class="underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            >Astro</a
          > and the <a
            href="https://workers.dev"
            target="_blank"
            class="underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            >Cloudflare Workers</a
          > ecosystem.
        </p>
        <p class="mb-6">
          Pre-wired with server-rendered Astro,
          <a
            href="https://orm.drizzle.team"
            target="_blank"
            class="underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            >Drizzle</a
          >,
          <a
            href="https://www.better-auth.com"
            target="_blank"
            class="underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            >Better Auth</a
          >, email,
          <a
            href="https://tailwindcss.com"
            target="_blank"
            class="underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            >Tailwind</a
          >, and
          <a
            href="https://ui.bejamas.com"
            target="_blank"
            class="underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
            >bejamas/ui</a
          >.
          <!-- Designed to deploy directly on Cloudflare using
          <a href="https://developers.cloudflare.com/d1/" target="_blank" class="underline underline-offset-4">D1</a>,
          <a href="https://developers.cloudflare.com/r2/" target="_blank" class="underline underline-offset-4">R2</a>,
          <a href="https://workers.dev" target="_blank" class="underline underline-offset-4">Workers</a>,
          <a href="https://developers.cloudflare.com/queues/" target="_blank" class="underline underline-offset-4">Queues</a>, and
          <a href="https://developers.cloudflare.com/kv/" target="_blank" class="underline underline-offset-4">KV</a>. -->
        </p>
        <p class="mb-6">
          Includes D1 migrations, typed auth locals, public-by-default route
          protection, Zod request parsing, Astro Actions, provider-based email,
          and an initial admin user script.
        </p>
        <p class="mb-6">
          Start new apps with low effort and high confidence.
        </p>
      </div>

      <!-- href="https://github.com/jyoungblood/vergekit"
        target="_blank" -->
      <a href="/docs" class="block mt-16 w-48 opacity-90 hover:opacity-70">
        <img src="/vk-crane-a.svg" />
      </a>

      <!-- <a
        href="/docs"
        class="text-xs underline underline-offset-4 hover:bg-neutral-800 hover:text-neutral-300"
        >Documentation</a
      > -->
    </div>
  </body>
</html>
