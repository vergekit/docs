---
import {
  default as NodeMysqlGuide,
  frontmatter,
  getHeadings,
} from '../../../../docs/alternative-deployments/node-mysql.mdx';
import { DocsLayout } from 'reallysimpledocs/components';

const page = {
  slug: 'alternative-deployments/node-mysql',
  file: 'alternative-deployments/node-mysql.mdx',
  extension: '.mdx',
  path: '/docs/alternative-deployments/node-mysql',
