---
import "../styles/global.css";

const quickFacts = [
  {
    label: "Runtime",
    value: "Cloudflare Workers",
  },
  {
    label: "Framework",
    value: "Astro server mode",
  },
  {
    label: "Database",
    value: "D1 with Drizzle",
  },
  {
    label: "Interface",
    value: "Tailwind CSS v4",
  },
];

const features = [
  {
    title: "Astro in server mode",
    body: "Strict TypeScript, the Cloudflare Workers adapter, pages, API routes, Actions, and middleware.",
  },
  {
    title: "D1-first database layer",
    body: "A D1 binding named DB, Drizzle schema, Drizzle Kit migrations, and local src/db modules.",
  },
  {
    title: "Better Auth flows",
    body: "Register, login, logout, email verification, forgot password, reset password, and D1 storage.",
  },
  {
    title: "Email providers",
    body: "Console, Cloudflare Email, Resend, Mailgun, and React Email templates.",
  },
  {
    title: "Server-side boundaries",
    body: "Middleware loads user, session, and isAuthenticated into typed Astro.locals.",
  },
  {
    title: "Validation and checks",
    body: "Zod request parsing, API response helpers, Vitest, happy-dom, oxlint, Prettier, and npm run verify.",
  },
];

const includedColumns = [
  [
    "Astro server app with strict TypeScript",
    "Cloudflare Workers adapter",
    "Tailwind CSS v4",
    "Local Astro UI components",
    "Lucide Astro icons",
  ],
  [
    "Better Auth with email/password",
    "Email verification",
    "Reset password",
    "Protected dashboard route",
    "Protected API routes",
  ],
  [
    "D1 database binding named DB",
    "Drizzle ORM",
    "Drizzle Kit migrations",
    "Astro Actions example",
    "Zod helpers",
  ],
  [
    "Auth email templates",
    "Console email provider",
    "Cloudflare Email",
    "Resend",
    "Mailgun",
  ],
];

const setupSteps = [
  ["01", "Install dependencies", "npm install"],
  ["02", "Create local runtime variables", "cp .dev.vars.example .dev.vars"],
  ["03", "Generate a Better Auth secret", "openssl rand -base64 32"],
  ["04", "Apply local D1 migrations", "npm run db:migrate:local"],
  ["05", "Start the app", "npm run dev"],
];

const concepts = [
  ["Use the stack", "Use Astro pages, API routes, Actions, middleware, and config before adding a new local abstraction."],
  ["D1 first", "D1 is the supported runtime database. PostgreSQL and MySQL are proof targets only in this release."],
  ["Server first", "Keep auth, database writes, email, and validation on the server."],
  ["Validate at the boundary", "Use Zod for request bodies, form input, and action input."],
  ["Middleware owns auth state", "Pages and routes should read user, session, and isAuthenticated from locals."],
  ["Keep it small", "VK does not include uploads, media processing, admin screens, RBAC, analytics, or a CLI yet."],
];

const notIncluded = [
  "Admin UI",
  "RBAC",
  "Uploads and storage adapters",
  "Media processing",
  "CLI installer",
  "Production PostgreSQL or MySQL runtime support",
];
---

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: #b4b4b4;
    color: #262626;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
  }
</style>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Verge Kit is a small Astro application boilerplate for Cloudflare Workers with D1, Drizzle, Better Auth, email, validation, middleware, and Tailwind already wired."
    />
    <title>Verge Kit - Web App Starter for Cloudflare Workers</title>
  </head>
  <body>
    <div class="min-h-screen overflow-hidden">
      <header class="mx-auto grid max-w-[92rem] grid-cols-6 gap-x-4 px-5 py-6 text-xs font-bold uppercase leading-tight text-[#262626] sm:grid-cols-12 sm:px-8 lg:px-12">
        <a href="#" class="col-span-2">Verge Kit</a>
        <p class="col-span-4 hidden sm:block">Astro application boilerplate</p>
        <nav aria-label="Primary" class="col-span-6 mt-5 grid grid-cols-4 gap-x-4 border-t border-[#262626] pt-2 sm:col-span-6 sm:mt-0 sm:border-t-0 sm:pt-0">
          <a href="#included">Included</a>
          <a href="#shape">Shape</a>
          <a href="#install">Install</a>
          <a href="#limits">Limits</a>
        </nav>
      </header>

      <main>
        <section class="mx-auto max-w-[92rem] px-5 pb-14 pt-5 sm:px-8 lg:px-12 lg:pb-24">
          <div class="grid grid-cols-6 gap-x-4 gap-y-8 sm:grid-cols-12">
            <div class="col-span-6 border-t border-[#262626] pt-3 text-xs font-bold uppercase leading-tight sm:col-span-3">
              <p>VK 001</p>
              <p><a href="/docs" class="hover:underline">Public docs</a></p>
              <p>Cloudflare Workers runtime</p>
            </div>
            <div class="col-span-6 border-t border-[#262626] pt-3 text-xs font-bold leading-tight sm:col-span-3">
              <p>A minimal full-stack Astro base for building real apps on Cloudflare.</p>
            </div>
            <div class="col-span-6 border-t border-[#262626] pt-3 text-xs font-bold leading-tight sm:col-span-3">
              <p>D1, Drizzle, Better Auth, email, validation, middleware, and Tailwind are already wired.</p>
            </div>
            <div class="col-span-6 border-t border-[#262626] pt-3 text-xs font-bold uppercase leading-tight sm:col-span-3">
              <p>Get started</p>
              <a href="#install" class="mt-1 block underline decoration-1 underline-offset-2">npm run dev</a>
            </div>

            <div class="col-span-6 mt-7 sm:col-span-12 lg:mt-14">
              <h1 class="max-w-[74rem] text-[4.15rem] font-black leading-[0.82] sm:text-[6.8rem] md:text-[8rem] lg:text-[9.5rem]">
                <span class="block">Astro app</span>
                <span class="block">boilerplate</span>
                <span class="block">for Workers</span>
              </h1>
            </div>

            <div class="col-span-6 mt-2 grid grid-cols-6 gap-x-4 gap-y-5 border-y border-[#262626] py-5 sm:col-span-12 sm:grid-cols-12 lg:mt-10">
              {quickFacts.map((fact) => (
                <div class="col-span-3 sm:col-span-3">
                  <p class="text-xs font-bold uppercase leading-none text-[#262626]/60">{fact.label}</p>
                  <p class="mt-3 text-lg font-black leading-[1.05] sm:text-2xl">{fact.value}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="bg-[#0779ac] text-[#f1eee7]">
          <div class="mx-auto grid max-w-[92rem] grid-cols-6 gap-x-4 px-5 py-14 sm:grid-cols-12 sm:px-8 lg:px-12 lg:py-20">
            <p class="col-span-6 border-t border-[#f1eee7] pt-3 text-xs font-bold uppercase leading-tight sm:col-span-2">
              Main position
            </p>
            <h2 class="col-span-6 mt-8 text-[3.5rem] font-black leading-[0.86] sm:col-span-10 sm:mt-0 sm:text-[5.8rem] md:text-[7rem] lg:text-[8.5rem]">
              <span class="block">Small</span>
              <span class="block">typed</span>
              <span class="block">application base</span>
            </h2>
            <p class="col-span-6 mt-10 max-w-xl border-t border-[#f1eee7] pt-3 text-lg font-bold leading-6 sm:col-start-7 sm:col-span-5">
              The goal is not to be a framework. The goal is to be a clean starting point that uses the platform and the stack directly.
            </p>
          </div>
        </section>

        <section id="included" class="mx-auto max-w-[92rem] px-5 py-14 sm:px-8 lg:px-12 lg:py-24">
          <div class="grid grid-cols-6 gap-x-4 gap-y-10 sm:grid-cols-12">
            <div class="col-span-6 sm:col-span-4">
              <p class="border-t border-[#262626] pt-3 text-xs font-bold uppercase leading-tight">Included</p>
              <h2 class="mt-8 text-5xl font-black leading-[0.9] sm:text-6xl lg:text-7xl">
                The pieces most apps need.
              </h2>
            </div>

            <div class="col-span-6 grid grid-cols-1 border-t border-[#262626] sm:col-span-8 sm:grid-cols-2 lg:grid-cols-3">
              {features.map((feature) => (
                <article class="min-h-48 border-b border-[#262626] py-5 sm:pr-5">
                  <h3 class="text-2xl font-black leading-none">{feature.title}</h3>
                  <p class="mt-5 max-w-sm text-sm font-bold leading-5 text-[#262626]/74">{feature.body}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="mx-auto max-w-[92rem] px-5 pb-14 sm:px-8 lg:px-12 lg:pb-24">
          <div class="grid grid-cols-6 gap-x-4 border-t border-[#262626] pt-4 sm:grid-cols-12">
            <p class="col-span-6 text-xs font-bold uppercase leading-tight sm:col-span-2">Package list</p>
            <div class="col-span-6 mt-8 grid gap-x-4 gap-y-8 sm:col-span-10 sm:mt-0 sm:grid-cols-4">
              {includedColumns.map((column) => (
                <ul class="space-y-3 text-xs font-bold leading-4">
                  {column.map((item) => (
                    <li class="border-t border-[#262626]/45 pt-2">{item}</li>
                  ))}
                </ul>
              ))}
            </div>
          </div>
        </section>

        <section id="shape" class="bg-[#262626] text-[#f1eee7]">
          <div class="mx-auto grid max-w-[92rem] grid-cols-6 gap-x-4 gap-y-10 px-5 py-14 sm:grid-cols-12 sm:px-8 lg:px-12 lg:py-24">
            <div class="col-span-6 sm:col-span-5">
              <p class="border-t border-[#f1eee7] pt-3 text-xs font-bold uppercase leading-tight">Project shape</p>
              <h2 class="mt-8 text-[4rem] font-black leading-[0.84] sm:text-[6rem] lg:text-[7.5rem]">
                <span class="block">D1</span>
                <span class="block">first.</span>
                <span class="block text-[#f1eee7]/55">Server</span>
                <span class="block text-[#f1eee7]/55">first.</span>
              </h2>
            </div>
            <div class="col-span-6 grid gap-x-4 gap-y-6 sm:col-span-7 sm:grid-cols-2">
              {concepts.map(([title, body]) => (
                <article class="border-t border-[#f1eee7] pt-3">
                  <h3 class="text-2xl font-black leading-none">{title}</h3>
                  <p class="mt-4 text-sm font-bold leading-5 text-[#f1eee7]/72">{body}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="install" class="mx-auto max-w-[92rem] px-5 py-14 sm:px-8 lg:px-12 lg:py-24">
          <div class="grid grid-cols-6 gap-x-4 gap-y-10 sm:grid-cols-12">
            <div class="col-span-6 sm:col-span-4">
              <p class="border-t border-[#262626] pt-3 text-xs font-bold uppercase leading-tight">Quickstart</p>
              <h2 class="mt-8 text-5xl font-black leading-[0.9] sm:text-6xl lg:text-7xl">
                Five steps to a local app.
              </h2>
            </div>
            <ol class="col-span-6 border-t border-[#262626] sm:col-span-8">
              {setupSteps.map(([number, title, command]) => (
                <li class="grid gap-x-4 border-b border-[#262626] py-4 sm:grid-cols-[5rem_1fr_1.25fr] sm:items-start">
                  <span class="text-5xl font-black leading-none">{number}</span>
                  <span class="mt-2 text-2xl font-black leading-none sm:mt-1">{title}</span>
                  <code class="mt-4 block overflow-x-auto bg-[#262626] px-3 py-2 text-sm font-bold text-[#f1eee7] sm:mt-0">
                    {command}
                  </code>
                </li>
              ))}
            </ol>
          </div>
        </section>

        <section class="bg-[#bd171d] text-[#f1eee7]">
          <div class="mx-auto grid max-w-[92rem] grid-cols-6 gap-x-4 gap-y-10 px-5 py-14 sm:grid-cols-12 sm:px-8 lg:px-12 lg:py-20">
            <p class="col-span-6 border-t border-[#f1eee7] pt-3 text-xs font-bold uppercase leading-tight sm:col-span-2">
              Deployment
            </p>
            <h2 class="col-span-6 text-[3.75rem] font-black leading-[0.86] sm:col-span-5 sm:text-[5.5rem] lg:text-[7rem]">
              Wrangler workflow
            </h2>
            <div class="col-span-6 grid gap-x-4 gap-y-5 text-sm font-bold leading-5 sm:col-span-5 sm:grid-cols-2">
              <p class="border-t border-[#f1eee7] pt-3">
                Create D1, set Better Auth secrets, configure email, apply remote migrations, run verification, then deploy.
              </p>
              <ul class="space-y-3">
                <li class="border-t border-[#f1eee7] pt-2">npx wrangler d1 create vk</li>
                <li class="border-t border-[#f1eee7] pt-2">npm run db:migrate:remote</li>
                <li class="border-t border-[#f1eee7] pt-2">npm run build</li>
                <li class="border-t border-[#f1eee7] pt-2">npx wrangler deploy</li>
              </ul>
            </div>
          </div>
        </section>

        <section id="limits" class="mx-auto max-w-[92rem] px-5 py-14 sm:px-8 lg:px-12 lg:py-24">
          <div class="grid grid-cols-6 gap-x-4 gap-y-10 sm:grid-cols-12">
            <div class="col-span-6 sm:col-span-5">
              <p class="border-t border-[#262626] pt-3 text-xs font-bold uppercase leading-tight">Not included yet</p>
              <h2 class="mt-8 text-[3.9rem] font-black leading-[0.84] sm:text-[5.6rem] lg:text-[7.5rem]">
                The boilerplate stays small.
              </h2>
            </div>
            <div class="col-span-6 border-t border-[#262626] sm:col-span-7">
              {notIncluded.map((item) => (
                <p class="grid grid-cols-[4rem_1fr] border-b border-[#262626] py-4 text-xl font-black leading-none sm:text-3xl">
                  <span class="text-sm leading-none text-[#262626]/55">No.</span>
                  <span>{item}</span>
                </p>
              ))}
            </div>
          </div>
        </section>
      </main>

      <footer class="mx-auto grid max-w-[92rem] grid-cols-6 gap-x-4 border-t border-[#262626] px-5 py-6 text-xs font-bold uppercase leading-tight sm:grid-cols-12 sm:px-8 lg:px-12">
        <p class="col-span-6 sm:col-span-5">Verge Kit is a small Astro application boilerplate for Cloudflare Workers.</p>
        <a href="#" class="col-span-6 mt-4 sm:col-span-2 sm:col-start-11 sm:mt-0">Back to top</a>
      </footer>
    </div>
  </body>
</html>
